# Copy to `.env`. Compose reads `.env` for variable substitution and passes it into containers.

# Optional: override published ports (host:container is set in docker-compose.yml).
# POSTGRES_PUBLISH_PORT=5432
# APP_PUBLISH_PORT=8000

# DB password (must match DATABASE_URL below when connecting from the host).
POSTGRES_PASSWORD=postgres

# Use when the API runs on your machine and Postgres is this Compose stack on port 5432.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/dietly

# The `app` service overrides DATABASE_URL to host `db` inside Docker — keep DATABASE_URL here for host-side tools / optional local uvicorn.

SCHEMA_AUTO_CREATE=false

FRONTEND_URL=http://localhost:3000

JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-16-chars

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Base URL embedded in stored image URLs (must reach this API’s ``/media`` route).
PUBLIC_MEDIA_BASE_URL=http://127.0.0.1:8000

LLM_PROVIDER=groq

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

GROQ_API_KEY=
# Must be a Groq vision model (text-only models return HTTP 400 for images).
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_BASE_URL=https://api.groq.com/openai/v1

OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llava

BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# Only when LLM_PROVIDER=bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

DEFAULT_AVATAR_URL=

PUBLIC_ANALYZE_DAILY_LIMIT=5

ENVIRONMENT=development
