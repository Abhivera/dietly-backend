# =============================================================================
# Calovia API — environment template
# =============================================================================
# 1. Copy this file to `.env` in the same directory (calovia-backend/).
# 2. Fill in required values (marked REQUIRED below).
# 3. Start DynamoDB Local: `docker compose up -d dynamodb`
# 4. Run API locally: `uvicorn app.main:app --reload --port 8000`
#
# Database: Amazon DynamoDB. On startup the API creates tables when
# SCHEMA_AUTO_CREATE=true. No migration files or data seeding required.
# =============================================================================

# -----------------------------------------------------------------------------
# DynamoDB (REQUIRED)
# -----------------------------------------------------------------------------
# Table name prefix (tables: {prefix}-users, {prefix}-images, etc.)
DYNAMODB_TABLE_PREFIX=calovia

# DynamoDB Local (dev). Omit or leave empty to use real AWS DynamoDB.
DYNAMODB_ENDPOINT_URL=http://127.0.0.1:8001

# AWS credentials — use dummy values for DynamoDB Local; real keys for AWS.
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_REGION=ap-south-1

# true = create DynamoDB tables on startup if they do not exist
SCHEMA_AUTO_CREATE=true

# -----------------------------------------------------------------------------
# App (REQUIRED / recommended)
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
PUBLIC_MEDIA_BASE_URL=http://127.0.0.1:8000
ENVIRONMENT=development

# Optional Compose port overrides (defaults: 8001 / 8000)
# DYNAMODB_PUBLISH_PORT=8001
# APP_PUBLISH_PORT=8000

# -----------------------------------------------------------------------------
# Firebase Authentication (REQUIRED)
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# -----------------------------------------------------------------------------
# LLM — meal image analysis
# -----------------------------------------------------------------------------
LLM_PROVIDER=groq

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_BASE_URL=https://api.groq.com/openai/v1

OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llava
OLLAMA_API_KEY=

BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
DEFAULT_AVATAR_URL=
PUBLIC_ANALYZE_DAILY_LIMIT=5
UPLOAD_DIR=uploads
